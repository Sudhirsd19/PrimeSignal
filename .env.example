# ═══════════════════════════════════════════════════════════════
# PrimeSignal Configuration Template
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════

# Binance API Configuration
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_api_secret_here
USE_TESTNET=True

# Exchange Type: 'spot' or 'futures' (Binance Futures for short-selling)
EXCHANGE_TYPE=spot

# Trading Settings
SYMBOL=BTC/USDT
TRADE_AMOUNT=0.001

# Advanced Risk Settings
RISK_PCT=1.0                  # Risk 1.0% of total balance per trade
MAX_DAILY_LOSS_PCT=5.0        # Daily circuit breaker at 5.0% loss
MAX_OPEN_TRADES=3             # Max concurrent active trades
TRAILING_STOP_PCT=0.015       # 1.5% trailing stop-loss buffer
MIN_RISK_REWARD_RATIO=2.0     # Minimum RR ratio (1:2)

# Multi-Timeframe Strategy Parameters
HTF_TIMEFRAME=1h              # Higher Timeframe for trend filter
LTF_TIMEFRAME=5m              # Lower Timeframe for execution entries
SHORT_EMA=9
LONG_EMA=21
TREND_EMA=200                 # Trend filter EMA on HTF
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
ATR_PERIOD=14

# Machine Learning Confirmation Settings
ML_CONFIRMATION_THRESHOLD=0.55
ML_TRAIN_BARS=2000
TEST_MODE=False
PAPER_TRADING=True

# Telegram Alerts (Optional)
TELEGRAM_TOKEN=your_telegram_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# CoinDCX API Configuration
COINDCX_API_KEY=your_coindcx_key_here
COINDCX_SECRET_KEY=your_coindcx_secret_here
COINDCX_TRADE_INR=True

# Futures Settings (only used when EXCHANGE_TYPE=futures)
FUTURES_LEVERAGE=1
FUTURES_MARGIN_MODE=isolated
